# Local Windows / Electron development uses SQLite:
DATABASE_URL="file:../dev.db"

# Netlify production should use a hosted Postgres URL from Neon or Supabase:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Use a long random value in production. Do not reuse this placeholder.
SESSION_SECRET="replace-with-a-long-random-secret"

# Server-side only. Rotate before public launch if this key was shared during development.
YOUTUBE_API_KEY=""

# Local HTTP: false. Netlify HTTPS: true.
COOKIE_SECURE="false"

# Netlify production:
# NETLIFY="true"
# COOKIE_SECURE="true"
# NETLIFY_NEXT_SKEW_PROTECTION="true"
# NEXT_PUBLIC_SITE_URL="https://your-temporary-site.netlify.app"
# NODE_VERSION="20"
